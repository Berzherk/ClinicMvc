@* Partial View за приказ на слободните термини, групирани по доктор *@
@model IEnumerable<FreeSlot>

@if (!Model.Any())
{
    <div class="alert alert-warning">Нема слободни термини за избраните филтри.</div>
}
else
{
    @* Групирај ги термините по доктор за прегледен приказ *@
    @foreach (var group in Model.GroupBy(s => new { s.DoctorId, s.DoctorName, s.DoctorSpecialty }))
    {
        <div class="card mb-3">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <div>
                    <strong>@group.Key.DoctorName</strong>
                    @if (!string.IsNullOrEmpty(group.Key.DoctorSpecialty))
                    {
                        <span class="text-muted"> — @group.Key.DoctorSpecialty</span>
                    }
                </div>
                <span class="badge bg-success">@group.Count() слободни термини</span>
            </div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var slot in group)
                    {
                        <span class="badge bg-primary fs-6 p-2">
                            @slot.Time.ToString(@"hh\:mm")
                        </span>
                    }
                </div>
            </div>
        </div>
    }
}
