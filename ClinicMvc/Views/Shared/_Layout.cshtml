<!DOCTYPE html>
<html lang="mk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Клиника</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark px-3">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">Клиника</a>
        <div class="navbar-nav ms-3 flex-grow-1">
            @* Линковите се прикажуваат само ако е најавен соодветна улога *@
            @if (User.IsInRole("Administrator"))
            {
                <a class="nav-link" asp-controller="Doctors" asp-action="Index">Доктори</a>
                <a class="nav-link" asp-controller="Patients" asp-action="Index">Пациенти</a>
                <a class="nav-link" asp-controller="Appointments" asp-action="Index">Термини</a>
                <a class="nav-link" asp-controller="AuditLogs" asp-action="Index">Логови</a>
                <a class="nav-link" asp-controller="Users" asp-action="Index">Корисници</a>
            }
            @if (User.IsInRole("Doctor"))
            {
                <a class="nav-link" asp-controller="DoctorDashboard" asp-action="Index">Мој dashboard</a>
                <a class="nav-link" asp-controller="Appointments" asp-action="Index">Мои термини</a>
                <a class="nav-link" asp-controller="Patients" asp-action="Index">Пациенти</a>
            }
            @if (User.IsInRole("Patient"))
            {
                <a class="nav-link" asp-controller="PatientPortal" asp-action="Index">Мои термини</a>
                <a class="nav-link" asp-controller="PatientPortal" asp-action="AvailableSlots">Закажи термин</a>
                <a class="nav-link" asp-controller="PatientPortal" asp-action="Profile">Мој профил</a>
            }
        </div>

        @* Прикажи "Најави се" или "Одјава" зависно од состојбата *@
        @if (User.Identity?.IsAuthenticated == true)
        {
            <span class="text-white me-3">
                @User.Identity!.Name
                <span class="badge bg-secondary">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
            </span>
            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-light btn-sm">Одjava</button>
            </form>
        }
        else
        {
            <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Login">Најави се</a>
        }
    </nav>

    <main class="container mt-4 flex-grow-1">
        @RenderBody()
    </main>

    @* Footer - заеднички за сите страници, секогаш при дното на екранот *@
    <footer class="bg-dark text-white-50 py-3 mt-4">
        <div class="container d-flex justify-content-between align-items-center small">
            <span>&copy; @DateTime.Now.Year Clinic Management System</span>
            <span>Верзија 1.0</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
