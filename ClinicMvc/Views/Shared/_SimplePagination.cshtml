@* Заедничка пагинација преку обични линкови (page=N во query string).
   Се користи на страници кои не се AJAX-управувани (Doctors, Patients, Users, AuditLogs).
   ВАЖНО: ги задржува сите тековни query string параметри (филтри) - само "page" се менува,
   инаку Претходна/Следна би ги избришале активните филтри при пребарување. *@
@model PaginationInfo

@{
    bool isFirstPage = Model.CurrentPage <= 1;
    bool isLastPage  = Model.CurrentPage >= Model.TotalPages;

    // Изгради query string кој ги задржува сите постоечки параметри освен "page"
    string BuildPageUrl(int page)
    {
        var query = new Dictionary<string, Microsoft.Extensions.Primitives.StringValues>(Context.Request.Query);
        query["page"] = page.ToString();
        return Context.Request.Path + QueryString.Create(query);
    }
}

@if (Model.TotalCount == 0)
{
    <p class="text-muted text-center mt-3">Нема пронајдени записи.</p>
}
else
{
    <nav class="d-flex justify-content-between align-items-center mt-3">
        @if (isFirstPage)
        {
            <span class="btn btn-outline-secondary btn-sm disabled">Претходна</span>
        }
        else
        {
            <a href="@BuildPageUrl(Model.CurrentPage - 1)" class="btn btn-outline-secondary btn-sm">Претходна</a>
        }

        <span class="text-muted small">
            Страна @Model.CurrentPage од @Model.TotalPages (@Model.TotalCount вкупно)
        </span>

        @if (isLastPage)
        {
            <span class="btn btn-outline-secondary btn-sm disabled">Следна</span>
        }
        else
        {
            <a href="@BuildPageUrl(Model.CurrentPage + 1)" class="btn btn-outline-secondary btn-sm">Следна</a>
        }
    </nav>
}
