@model bool
@{
    ViewData["Title"] = "Потврда на е-пошта";
    Layout = "_LoginLayout";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="card shadow text-center" style="width: 480px;">
        <div class="card-body p-4">
            @if (Model)
            {
                <i class="bi bi-check-circle display-4 text-success"></i>
                <h4 class="mt-3">Е-поштата е потврдена!</h4>
                <p class="text-muted">Сега можете да се најавите со вашето корисничко ime и лозинка.</p>
            }
            else
            {
                <i class="bi bi-x-circle display-4 text-danger"></i>
                <h4 class="mt-3">Потврдата не успеа</h4>
                <p class="text-muted">@(ViewBag.Error ?? "Линкот за потврда не е валиден или е истечен.")</p>
            }
            <a asp-action="Login" class="btn btn-primary">Оди кон најава</a>
        </div>
    </div>
</div>
