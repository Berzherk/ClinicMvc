@{
    ViewData["Title"] = "Проверете ја вашата е-пошта";
    Layout = "_LoginLayout";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="card shadow text-center" style="width: 480px;">
        <div class="card-body p-4">
            <i class="bi bi-envelope-check display-4 text-success"></i>
            <h4 class="mt-3">Проверете ја вашата е-пошта</h4>
            <p class="text-muted">
                Испративме линк за потврда до вашата е-пошта адреса. Кликнете на линкот
                за да ја активирате сметката, потоа најавете се.
            </p>
            <a asp-action="Login" class="btn btn-primary">Оди кон најава</a>
        </div>
    </div>
</div>
