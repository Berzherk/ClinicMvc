@* Partial View за табеларен приказ на термините/слотовите - го користат Index и AJAX повиците *@
@model IEnumerable<Appointment>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Датум</th>
            <th>Време</th>
            <th>Пациент</th>
            <th>Лекар</th>
            <th>Специјалност</th>
            <th>Статус</th>
            <th>Акции</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="7" class="text-center text-muted">Нема термини.</td>
            </tr>
        }
        else
        {
            @foreach (var a in Model)
            {
                <tr id="appointment-row-@a.Id">
                    <td>@a.AppointmentDate.ToString("dd.MM.yyyy")</td>
                    <td>@a.AppointmentTime.ToString(@"hh\:mm")</td>
                    <td>@(a.PatientName ?? "—")</td>
                    <td>@a.DoctorName</td>
                    <td>@a.DoctorSpecialty</td>
                    <td>
                        @{
                            // Секој статус добива своја боја за полесно визуелно снаоѓање
                            var badgeClass = a.Status switch
                            {
                                "Free"      => "bg-light text-dark border",
                                "Booked"    => "bg-primary",
                                "Completed" => "bg-success",
                                "Cancelled" => "bg-danger",
                                _           => "bg-light text-dark"
                            };
                        }
                        <span class="badge @badgeClass">@a.Status</span>
                    </td>
                    <td class="text-nowrap">
                        @* Слот е сè уште слободен - може да се менува/брише слободно *@
                        @if (a.Status == "Free")
                        {
                            <button class="btn btn-sm btn-warning" onclick="openEditModal(@a.Id)" title="Измени слот">
                                <i class="bi bi-pencil-fill"></i>
                            </button>
                            <button class="btn btn-sm btn-danger" onclick="deleteAppointment(@a.Id)" title="Избриши слот">
                                <i class="bi bi-trash-fill"></i>
                            </button>
                        }

                        @* Резервиран термин - докторот може да го заврши или откаже *@
                        @if (a.Status == "Booked")
                        {
                            <button class="btn btn-sm btn-success" onclick="openCompleteModal(@a.Id)" title="Означи завршено">
                                <i class="bi bi-check-lg"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" onclick="openCancelModal(@a.Id)" title="Откажи термин">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        }
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
