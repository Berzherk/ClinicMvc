@* Модел кој содржи филтри и dropdown опции за dashboard страницата *@
@model AppointmentIndexViewModel
@{
    ViewData["Title"] = "Термини";
}

@* Наслов и копчиња за акции *@
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Термини</h2>
    <div class="d-flex gap-2">
        <a id="exportExcelBtn" href="#" class="btn btn-outline-success btn-sm">Export Excel</a>
        <a id="exportPdfBtn" href="#" class="btn btn-outline-danger btn-sm">Export PDF</a>
        <button class="btn btn-primary" onclick="openCreateModal()">+ Нов термински слот</button>
    </div>
</div>

@* ══════════════════ Dashboard приказ - два столба ══════════════════ *@
<div class="row">

    @* ─────────── Лева страна (col-md-3): Статистика + Филтри ─────────── *@
    <div class="col-md-3">

        @* Контејнер за статистика - се вчитува и освежува преку AJAX *@
        <div id="statsContainer">
            <div class="text-center py-3">
                <div class="spinner-border spinner-border-sm text-primary"></div>
            </div>
        </div>

        @* Картичка со филтри за пребарување *@
        <div class="card card-body">
            <h6 class="mb-3">Филтри</h6>

            <div class="mb-2">
                <label class="form-label small">Ime на пациент</label>
                <input type="text" id="filterPatientFirstName" class="form-control form-control-sm"
                       placeholder="пр. Ана" />
            </div>

            <div class="mb-2">
                <label class="form-label small">Презиме на пациент</label>
                <input type="text" id="filterPatientLastName" class="form-control form-control-sm"
                       placeholder="пр. Стојанова" />
            </div>

            <div class="mb-2">
                <label class="form-label small">ЕМБГ на пациент</label>
                <input type="text" id="filterPatientEmbg" class="form-control form-control-sm"
                       placeholder="пр. 12034567" />
            </div>

            <div class="mb-2">
                <label class="form-label small">Ime на лекар</label>
                <input type="text" id="filterDoctorName" class="form-control form-control-sm"
                       placeholder="пр. Петров" />
            </div>

            <div class="mb-2">
                <label class="form-label small">Специјалност</label>
                <select id="filterSpecialty" class="form-select form-select-sm">
                    <option value="">-- Сите --</option>
                    @foreach (var s in Model.Specialties)
                    {
                        <option value="@s.Value">@s.Text</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label small">Датум</label>
                <input type="date" id="filterDate" class="form-control form-control-sm" />
            </div>

            <button type="button" class="btn btn-outline-secondary btn-sm w-100" onclick="clearFilters()">
                Исчисти филтри
            </button>
        </div>
    </div>

    @* ─────────── Средина (col-md-6): Сортирање + Табела + Пагинација ─────────── *@
    <div class="col-md-6">

        @* Контроли за сортирање, поставени над табелата *@
        <div class="d-flex justify-content-end align-items-center mb-2 gap-2">
            <label class="form-label small mb-0">Подреди по:</label>
            <select id="sortBy" class="form-select form-select-sm w-auto">
                <option value="Date">Датум</option>
                <option value="Time">Време</option>
                <option value="Patient">Пациент</option>
                <option value="Doctor">Лекар</option>
                <option value="Status">Статус</option>
            </select>
            <button type="button" id="sortDirectionBtn" class="btn btn-outline-secondary btn-sm"
                    onclick="toggleSortDirection()" title="Смени насока на сортирање">
                Растечки
            </button>
        </div>

        @* Контејнер каде AJAX ја вчитува табелата со термини (постоечкиот Partial View).
           table-responsive овозможува хоризонтално скролање наместо преклопување
           со панелот за слободни термини кога табелата е преширока за колоната. *@
        <div id="tableContainer" class="table-responsive">
            <div class="text-center py-4">
                <div class="spinner-border text-primary"></div>
                <p class="mt-2">Се вчитува...</p>
            </div>
        </div>

        @* Контејнер за пагинација - под табелата *@
        <div id="paginationContainer"></div>
    </div>

    @* ─────────── Десна страна (col-md-3): Слободни термини ─────────── *@
    @* sticky-top го задржува панелот видлив додека се скролува страницата, а
       внатрешниот overflow-y спречува панелот да ја издолжи целата страница
       кога има многу доктори со слободни термини. *@
    <div class="col-md-3">
        <div class="card" style="position: sticky; top: 1rem;">
            <div class="card-header bg-dark text-white">Слободни термини</div>
            <div class="card-body">
                <div class="mb-2">
                    <label class="form-label small">Лекар</label>
                    <select id="slotsFilterDoctor" class="form-select form-select-sm">
                        <option value="">-- Сите активни лекари --</option>
                        @foreach (var d in Model.Doctors)
                        {
                            <option value="@d.Value">@d.Text</option>
                        }
                    </select>
                </div>
                <div class="mb-2">
                    <label class="form-label small">Специјалност</label>
                    <select id="slotsFilterSpecialty" class="form-select form-select-sm">
                        <option value="">-- Сите --</option>
                        @foreach (var s in Model.Specialties)
                        {
                            <option value="@s.Value">@s.Text</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label small">Датум</label>
                    <input type="date" id="slotsFilterDate" class="form-control form-control-sm" />
                </div>

                @* Фиксна висина + внатрешен скрол - панелот не ја издолжува страницата *@
                <div id="slotsContainer" style="max-height: 60vh; overflow-y: auto;">
                    <p class="text-muted small mb-0">Изберете датум за да ги видите слободните термини.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@* Модал за креирање и измена на термински слот - САМО Doctor/Date/Time.
   Пациентот НИКОГАШ не се доделува рачно овде - тоа го прави пациентот сам
   преку резервација на слотот (PatientPortal). *@
<div class="modal fade" id="appointmentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="appointmentModalTitle">Нов термински слот</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="appointmentForm">
                    @* Безбедносен токен за заштита од CSRF напади *@
                    @Html.AntiForgeryToken()
                    @* Скриено поле за ID - 0 значи нов слот, поинаку е измена *@
                    <input type="hidden" id="appointmentId" name="Id" value="0" />

                    @* Dropdown за избор на лекар - се полни преку AJAX *@
                    <div class="mb-3">
                        <label class="form-label">Лекар <span class="text-danger">*</span></label>
                        <select class="form-select" id="doctorId" name="DoctorId" required>
                            <option value="">-- Избери лекар --</option>
                        </select>
                    </div>

                    @* Датум на слотот - не смее да биде во минатото *@
                    <div class="mb-3">
                        <label class="form-label">Датум <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" id="appointmentDate"
                               name="Date" required />
                    </div>

                    @* Време на слотот - само од фиксната мрежа на секои 30 минути (08:00-16:00),
                       не смее да се внесе произволно време. Опциите ги генерира JS (fillTimeOptions). *@
                    <div class="mb-3">
                        <label class="form-label">Време <span class="text-danger">*</span></label>
                        <select class="form-select" id="appointmentTime" name="Time" required>
                            <option value="">-- Избери време --</option>
                        </select>
                    </div>

                    @* Порака за грешка - скриена по default, се прикажува при валидациска грешка *@
                    <div id="appointmentFormErrors" class="alert alert-danger d-none"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Откажи</button>
                <button type="button" class="btn btn-primary" onclick="saveAppointment()">Зачувај</button>
            </div>
        </div>
    </div>
</div>

@* Модал за потврда на бришење *@
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Избриши термин</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Дали сте сигурни дека сакате да го избришете овој термин/слот?</p>
                <form id="deleteForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteAppointmentId" value="0" />
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Откажи</button>
                <button type="button" class="btn btn-danger" onclick="confirmDelete()">Избриши</button>
            </div>
        </div>
    </div>
</div>

@* Модал за означување термин како завршен *@
<div class="modal fade" id="completeModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">Означи термин како завршен</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Внесете белешка за прегледот (незадолжително):</p>
                <form id="completeForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="completeAppointmentId" value="0" />
                    <div class="mb-3">
                        <label class="form-label">Белешки</label>
                        <textarea class="form-control" id="completeNotes" rows="3"
                                  placeholder="Опис на прегледот, наод, препораки..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Откажи</button>
                <button type="button" class="btn btn-success" onclick="confirmComplete()">Заврши</button>
            </div>
        </div>
    </div>
</div>

@* Модал за откажување резервиран термин - пациентот се известува по е-пошта *@
<div class="modal fade" id="cancelModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title">Откажи термин</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Пациентот автоматски ќе биде известен по е-пошта дека терминот е откажан.</p>
                <form id="cancelForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="cancelAppointmentId" value="0" />
                    <div class="mb-3">
                        <label class="form-label">Причина за откажување (незадолжително)</label>
                        <textarea class="form-control" id="cancelReason" rows="2"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Назад</button>
                <button type="button" class="btn btn-danger" onclick="confirmCancel()">Откажи термин</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Иницијализација на Bootstrap модали
    const appointmentModal = new bootstrap.Modal(document.getElementById('appointmentModal'));
    const deleteModal      = new bootstrap.Modal(document.getElementById('deleteModal'));
    const completeModal    = new bootstrap.Modal(document.getElementById('completeModal'));
    const cancelModal      = new bootstrap.Modal(document.getElementById('cancelModal'));

    // Глобална променлива за чување на dropdown податоци (лекари) - за модалот
    let dropdowns = { doctors: [], statuses: [] };

    // Глобална состојба на dashboard-от: тековна страница и насока на сортирање.
    let currentPage      = 1;
    let sortDirection     = 'asc';

    // ── Читање на тековните вредности на филтрите од полињата ──────────
    function getFilterParams() {
        return {
            PatientFirstName: $('#filterPatientFirstName').val(),
            PatientLastName:  $('#filterPatientLastName').val(),
            PatientEmbg:      $('#filterPatientEmbg').val(),
            DoctorName:       $('#filterDoctorName').val(),
            Specialty:        $('#filterSpecialty').val(),
            Date:             $('#filterDate').val(),
            SortBy:           $('#sortBy').val(),
            SortDirection:    sortDirection,
            Page:             currentPage
        };
    }

    // ── Вчитување на табелата преку AJAX (постоечкиот Partial View _AppointmentsTable) ──
    function loadTable() {
        const params = getFilterParams();

        $('#tableContainer').html(`
            <div class="text-center py-4">
                <div class="spinner-border text-primary"></div>
                <p class="mt-2">Се вчитува...</p>
            </div>`);

        $.get('/Appointments/LoadTable', params, function(html) {
            $('#tableContainer').html(html);
        });
    }

    // ── Вчитување на пагинацијата преку AJAX ────────────────────────────
    function loadPagination() {
        const params = getFilterParams();
        $.get('/Appointments/LoadPagination', params, function(html) {
            $('#paginationContainer').html(html);
        });
    }

    // ── Вчитување на статистиката преку AJAX ────────────────────────────
    function loadStatistics() {
        const params = getFilterParams();
        $.get('/Appointments/LoadStatistics', params, function(html) {
            $('#statsContainer').html(html);
        });
    }

    // ── Ажурирање на линковите за извоз според тековните филтри ─────────
    function updateExportLinks() {
        const params = new URLSearchParams(getFilterParams()).toString();
        document.getElementById('exportExcelBtn').href = '/Appointments/ExportExcel?' + params;
        document.getElementById('exportPdfBtn').href   = '/Appointments/ExportPdf?' + params;
    }

    // ── Комбинирано освежување: табела + пагинација + статистика ───────
    function refreshAll() {
        loadTable();
        loadPagination();
        loadStatistics();
        updateExportLinks();
    }

    // ── Комбинирано освежување само на табела + пагинација ──────────────
    function refreshTableOnly() {
        loadTable();
        loadPagination();
        updateExportLinks();
    }

    // ── Смена на страница преку копчињата Претходна/Следна ──────────────
    function goToPage(page) {
        if (page < 1) return;
        currentPage = page;
        refreshTableOnly();
    }

    // ── При промена на филтер - врати се на страница 1 и освежи сè ──────
    function onFilterChanged() {
        currentPage = 1;
        refreshAll();
    }

    // Едноставен debounce за текстуалните полиња
    let debounceTimer;
    function debouncedFilterChange() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(onFilterChanged, 400);
    }

    $('#filterPatientFirstName, #filterPatientLastName, #filterPatientEmbg, #filterDoctorName')
        .on('input', debouncedFilterChange);

    $('#filterSpecialty, #filterDate').on('change', onFilterChanged);

    function clearFilters() {
        $('#filterPatientFirstName, #filterPatientLastName, #filterPatientEmbg, #filterDoctorName').val('');
        $('#filterSpecialty').val('');
        $('#filterDate').val('');
        onFilterChanged();
    }

    $('#sortBy').on('change', function() {
        currentPage = 1;
        refreshTableOnly();
    });

    function toggleSortDirection() {
        sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
        const btn = document.getElementById('sortDirectionBtn');
        btn.textContent = sortDirection === 'asc' ? 'Растечки' : 'Опаѓачки';
        currentPage = 1;
        refreshTableOnly();
    }

    // ── При вчитување на страницата ──────────────────────────────────────
    $(document).ready(function() {
        $.get('/Appointments/GetDropdowns', function(data) {
            dropdowns = data;
        });
        refreshAll();

        $('#slotsFilterDate').val(new Date().toISOString().split('T')[0]);
        loadFreeSlots();
    });

    // ── Панел за слободни термини (десна страна) ─────────────────────────
    function loadFreeSlots() {
        const date = $('#slotsFilterDate').val();

        const params = {
            DoctorId:  $('#slotsFilterDoctor').val(),
            Specialty: $('#slotsFilterSpecialty').val(),
            Date:      date
        };

        $('#slotsContainer').html(`
            <div class="text-center py-3">
                <div class="spinner-border spinner-border-sm text-primary"></div>
            </div>`);

        $.get('/FreeSlots/LoadSlots', params, function(html) {
            $('#slotsContainer').html(html);
        });
    }

    $('#slotsFilterDoctor, #slotsFilterSpecialty, #slotsFilterDate').on('change', loadFreeSlots);

    // ── Полнење на dropdown за лекар во Create/Edit модалот ──────────────
    function fillDropdowns(selectedDoctorId) {
        const doctorSel  = document.getElementById('doctorId');
        doctorSel.innerHTML  = '<option value="">-- Избери лекар --</option>';
        dropdowns.doctors.forEach(d => {
            doctorSel.appendChild(new Option(d.name, d.id, false, d.id == selectedDoctorId));
        });
    }

    // ── Полнење на dropdown за време - само фиксни термини на секои 30 минути,
    //    во работно време 08:00-16:00. Ова е единствениот избор - не смее да се
    //    внесе произволно време (истата мрежа што порано ја користеше панелот
    //    "Слободни термини" пред слотовите да станат зачувани редови). ──────
    function fillTimeOptions(selectedTime) {
        const timeSel = document.getElementById('appointmentTime');
        timeSel.innerHTML = '<option value="">-- Избери време --</option>';

        const startMinutes = 8 * 60;   // 08:00
        const endMinutes   = 16 * 60;  // 16:00 (исклучително - последен слот е 15:30)

        for (let m = startMinutes; m < endMinutes; m += 30) {
            const hh = String(Math.floor(m / 60)).padStart(2, '0');
            const mm = String(m % 60).padStart(2, '0');
            const value = `${hh}:${mm}`;
            timeSel.appendChild(new Option(value, value, false, value === selectedTime));
        }
    }

    // ── Отвори модал за креирање нов термински слот ──────────────────────
    function openCreateModal() {
        document.getElementById('appointmentModalTitle').textContent = 'Нов термински слот';
        document.getElementById('appointmentId').value   = '0';
        document.getElementById('appointmentDate').value = new Date().toISOString().split('T')[0];
        clearAppointmentValidation();
        fillDropdowns(0);
        fillTimeOptions('');
        appointmentModal.show();
    }

    // ── Отвори модал за измена на постоечки слободен слот ─────────────────
    function openEditModal(id) {
        $.get(`/Appointments/GetById/${id}`, function(a) {
            document.getElementById('appointmentModalTitle').textContent = 'Измени термински слот';
            document.getElementById('appointmentId').value   = a.id;
            document.getElementById('appointmentDate').value = a.appointmentDate?.split('T')[0];
            clearAppointmentValidation();
            fillDropdowns(a.doctorId);
            fillTimeOptions(a.appointmentTime?.substring(0, 5));
            appointmentModal.show();
        });
    }

    // ── Клиентска валидација на формата за слот ────────────────────────
    function validateAppointmentForm() {
        let isValid = true;

        const doctorId = document.getElementById('doctorId');
        if (!doctorId.value) { doctorId.classList.add('is-invalid'); isValid = false; }
        else { doctorId.classList.remove('is-invalid'); doctorId.classList.add('is-valid'); }

        const appointmentDate = document.getElementById('appointmentDate');
        if (!appointmentDate.value) { appointmentDate.classList.add('is-invalid'); isValid = false; }
        else { appointmentDate.classList.remove('is-invalid'); appointmentDate.classList.add('is-valid'); }

        const appointmentTime = document.getElementById('appointmentTime');
        if (!appointmentTime.value) { appointmentTime.classList.add('is-invalid'); isValid = false; }
        else { appointmentTime.classList.remove('is-invalid'); appointmentTime.classList.add('is-valid'); }

        return isValid;
    }

    function clearAppointmentValidation() {
        document.getElementById('appointmentFormErrors').classList.add('d-none');
        ['doctorId', 'appointmentDate', 'appointmentTime'].forEach(id => {
            document.getElementById(id).classList.remove('is-invalid', 'is-valid');
        });
    }

    // ── Зачувај термински слот - Create или Edit зависно од ID ───────────
    function saveAppointment() {
        if (!validateAppointmentForm()) return;

        const id    = document.getElementById('appointmentId').value;
        const url   = id === '0' ? '/Appointments/Create' : '/Appointments/Edit';
        const token = document.querySelector('#appointmentForm input[name="__RequestVerificationToken"]').value;

        const selectedDate = new Date(document.getElementById('appointmentDate').value);
        const today = new Date(); today.setHours(0, 0, 0, 0);
        if (selectedDate < today) {
            showError('Не може да се закаже термин за минат датум.');
            return;
        }

        const data = {
            Id:       id,
            DoctorId: document.getElementById('doctorId').value,
            Date:     document.getElementById('appointmentDate').value,
            Time:     document.getElementById('appointmentTime').value,
            __RequestVerificationToken: token
        };

        $.post(url, data)
            .done(function() {
                appointmentModal.hide();
                refreshAll();
            })
            .fail(function(xhr) {
                const response = xhr.responseJSON;
                showError(response?.errors?.join('<br>') || 'Грешка при зачувување.');
            });
    }

    function showError(msg) {
        const errDiv = document.getElementById('appointmentFormErrors');
        errDiv.innerHTML = msg;
        errDiv.classList.remove('d-none');
    }

    // ── Бришење термин/слот ────────────────────────────────────────────
    function deleteAppointment(id) {
        document.getElementById('deleteAppointmentId').value = id;
        deleteModal.show();
    }

    function confirmDelete() {
        const id    = document.getElementById('deleteAppointmentId').value;
        const token = document.querySelector('#deleteForm input[name="__RequestVerificationToken"]').value;

        $.post('/Appointments/Delete', { id: id, __RequestVerificationToken: token })
            .done(function() {
                deleteModal.hide();
                refreshAll();
            })
            .fail(function() {
                alert('Грешка при бришење.');
            });
    }

    // ── Означи термин како завршен ────────────────────────────────────
    function openCompleteModal(id) {
        document.getElementById('completeAppointmentId').value = id;
        document.getElementById('completeNotes').value = '';
        completeModal.show();
    }

    function confirmComplete() {
        const id    = document.getElementById('completeAppointmentId').value;
        const notes = document.getElementById('completeNotes').value;
        const token = document.querySelector('#completeForm input[name="__RequestVerificationToken"]').value;

        $.post('/Appointments/Complete', { id: id, notes: notes, __RequestVerificationToken: token })
            .done(function() {
                completeModal.hide();
                refreshAll();
            })
            .fail(function(xhr) {
                const response = xhr.responseJSON;
                alert(response?.errors?.join('\n') || 'Грешка при завршување на терминот.');
            });
    }

    // ── Откажи резервиран термин (испраќа е-пошта до пациентот) ────────
    function openCancelModal(id) {
        document.getElementById('cancelAppointmentId').value = id;
        document.getElementById('cancelReason').value = '';
        cancelModal.show();
    }

    function confirmCancel() {
        const id     = document.getElementById('cancelAppointmentId').value;
        const reason = document.getElementById('cancelReason').value;
        const token  = document.querySelector('#cancelForm input[name="__RequestVerificationToken"]').value;

        $.post('/Appointments/Cancel', { id: id, reason: reason, __RequestVerificationToken: token })
            .done(function() {
                cancelModal.hide();
                refreshAll();
            })
            .fail(function(xhr) {
                const response = xhr.responseJSON;
                alert(response?.errors?.join('\n') || 'Грешка при откажување на терминот.');
            });
    }
</script>
}
