@* Листа на сите CRUD активности - CREATE | Doctor | admin *@
@model IEnumerable<AuditLog>
@{
    ViewData["Title"] = "Audit Logs";
    var filter = (AuditLogFilter)ViewBag.Filter;
}

<h2 class="mb-3">Логови на активности</h2>

@* Филтри за пребарување - GET форма *@
<form method="get" asp-action="Index" class="card card-body mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-2">
            <label class="form-label small">Тип на акција</label>
            <select name="ActionType" class="form-select form-select-sm">
                <option value="">-- Сите --</option>
                @foreach (var action in new[] { "CREATE", "UPDATE", "DELETE" })
                {
                    if (filter.ActionType == action)
                    {
                        <option value="@action" selected>@action</option>
                    }
                    else
                    {
                        <option value="@action">@action</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small">Ентитет</label>
            <select name="EntityName" class="form-select form-select-sm">
                <option value="">-- Сите --</option>
                @foreach (var entity in new[] { "Doctor", "Patient", "Appointment", "User" })
                {
                    if (filter.EntityName == entity)
                    {
                        <option value="@entity" selected>@entity</option>
                    }
                    else
                    {
                        <option value="@entity">@entity</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small">Корисник</label>
            <input type="text" name="Username" value="@filter.Username" class="form-control form-control-sm" placeholder="пр. admin" />
        </div>
        <div class="col-md-2">
            <label class="form-label small">Од датум</label>
            <input type="date" name="DateFrom" value="@filter.DateFrom?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
        </div>
        <div class="col-md-2">
            <label class="form-label small">До датум</label>
            <input type="date" name="DateTo" value="@filter.DateTo?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-secondary btn-sm">Пребарај</button>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Исчисти</a>
        </div>
    </div>
</form>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Датум/Време</th>
            <th>Акција</th>
            <th>Ентитет</th>
            <th>ID</th>
            <th>Корисник</th>
            <th>Опис</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="6" class="text-center text-muted">Нема пронајдени записи.</td>
            </tr>
        }
        else
        {
            @foreach (var log in Model)
            {
                var badgeClass = log.ActionType switch
                {
                    "CREATE" => "bg-success",
                    "UPDATE" => "bg-warning text-dark",
                    "DELETE" => "bg-danger",
                    _        => "bg-secondary"
                };
                <tr>
                    <td>@log.LogDateTime.ToString("dd.MM.yyyy HH:mm:ss")</td>
                    <td><span class="badge @badgeClass">@log.ActionType</span></td>
                    <td>@log.EntityName</td>
                    <td>@log.EntityId</td>
                    <td>@log.Username</td>
                    <td>@log.Description</td>
                </tr>
            }
        }
    </tbody>
</table>

@await Html.PartialAsync("_SimplePagination", (PaginationInfo)ViewBag.Pagination)
